# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-template
# Load Order: 90 (loaded near-last, overrides all default and tool-specific settings)
#
# This file contains configuration values unique to this project that override
# defaults from earlier env files (00-core, 10-*, 20-*).
#
# Only add variables here that differ from the upstream defaults.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE OVERRIDES
# ================================================================================================

# Coverage provider (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Codecov requires a token for this project
CODECOV_TOKEN_REQUIRED=true

# Coverage exclusion paths (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/,plans/,docs/

# Skip URL checks in coverage reports
GO_COVERAGE_SKIP_URL_CHECKS=true
